{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/shop", "destination": "https://www.franalcazar.com/shop" },
    { "source": "/shop/(.*)", "destination": "https://www.franalcazar.com/shop/$1" }
  ]
}
